# App version is injected automatically from package.json at build time.
# No environment variables are required for a plain localhost dev setup.

# If you run the dev server behind a reverse proxy (e.g. Traefik), add your
# hostname here so Next.js allows the HMR WebSocket connection.
# Comma-separated, no protocol prefix.
# NEXT_DEV_ALLOWED_ORIGINS=your-dev-domain.example.com
